# Example Terraform — copy to main.tf and customize

variable "project_id" {
  type = string
}

variable "bucket_name" {
  type = string
}

variable "region" {
  type    = string
  default = "northamerica-northeast1"
}

provider "google" {
  project = var.project_id
  region  = var.region
}

resource "google_storage_bucket" "na_telecom_raw" {
  name     = var.bucket_name
  location = var.region

  uniform_bucket_level_access = true

  lifecycle_rule {
    condition { age = 90 }
    action { type = "Delete" }
  }
}

resource "google_bigquery_dataset" "na_telecom" {
  dataset_id = "na_telecom"
  location   = var.region

  description = "NA telecom market intelligence pipeline"
}

output "gcs_bucket" {
  value = google_storage_bucket.na_telecom_raw.name
}

output "bq_dataset" {
  value = google_bigquery_dataset.na_telecom.dataset_id
}
